{
  "name": "convert-codebase-casing",
  "version": "0.3.2",
  "description": "Convert an entire JS/TS codebase to either kebab-case or snake-case",
  "keywords": [
    "camel-case",
    "case",
    "casing",
    "codebase",
    "convert",
    "files",
    "javascript",
    "kebab-case",
    "rename",
    "snake-case",
    "transform",
    "typescript"
  ],
  "license": "MIT",
  "author": "Thijs Koerselman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0x80/convert-codebase-casing.git"
  },
  "bin": {
    "convert-codebase-casing": "dist/main.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "format": "oxfmt",
    "lint": "oxlint -c .oxlintrc.json --type-aware",
    "check-format": "oxfmt --check",
    "check-types": "tsc --noEmit",
    "prepare": "pnpm check-types && pnpm build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "fs-extra": "^11.2.0",
    "globby": "^14.0.2",
    "jscodeshift": "^0.15.2",
    "meow": "^14.0.0",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-syntax-jsx": "^7.24.7",
    "@babel/plugin-syntax-typescript": "^7.24.7",
    "@codecompose/typescript-config": "^3.0.0",
    "@types/babel__core": "^7.20.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jscodeshift": "^0.11.11",
    "@types/node": "^25.2.3",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "oxlint-tsgolint": "^0.15.0",
    "tsdown": "0.20.3",
    "typescript": "6.0.0-beta",
    "vite": "^7.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "packageManager": "pnpm@9.0.0+sha256.bdfc9a7b372b5c462176993e586492603e20da5864d2f8881edc2462482c76fa"
}
